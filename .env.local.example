# Optional app-only configs for local development
NEXT_PUBLIC_APP_NAME=Seedance Video PoC

# Server-side API keys (never exposed to the client)
BYTEPLUS_API_KEY=your_byteplus_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Per-service spending caps in USD. When the app keys hit these limits,
# users are prompted to supply their own keys (BYOK).
BYTEPLUS_USD_LIMIT=2
OPENROUTER_USD_LIMIT=2

# Upstash Redis (for atomic spend tracking across serverless invocations).
# Get these from https://upstash.com (free tier) or via the Vercel Marketplace
# integration (adds them automatically to Vercel env vars).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
